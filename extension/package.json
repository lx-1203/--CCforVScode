{
  "name": "xingjiclaudecode",
  "displayName": "星迹的CC✨",
  "description": "星迹的CC✨ - 基于 Claude Code 的汉化增强版 (预发送 Pre-Send 功能)",
  "version": "2.1.95",
  "publisher": "xingji",
  "license": "© Anthropic PBC. All rights reserved. Use is subject to the Legal Agreements outlined here: https://code.claude.com/docs/en/legal-and-compliance.",
  "bugs": {
    "url": "https://github.com/anthropics/claude-code/issues",
    "email": "support@anthropic.com"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "claude",
    "sonnet",
    "ai",
    "mcp",
    "agent"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onWebviewPanel:claudeVSCodePanel"
  ],
  "icon": "resources/claude-logo.png",
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "星迹的CC✨",
      "properties": {
        "claudeCode.environmentVariables": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "环境变量名称"
              },
              "value": {
                "type": "string",
                "description": "环境变量值"
              }
            },
            "required": [
              "name",
              "value"
            ]
          },
          "default": [],
          "description": "启动 Claude 时设置的环境变量。\n\n建议在 Claude 的 settings.json 中设置环境变量。\n详见文档: https://code.claude.com/docs/en/settings"
        },
        "claudeCode.useTerminal": {
          "type": "boolean",
          "default": false,
          "description": "在终端中启动 Claude，而非原生界面。"
        },
        "claudeCode.allowDangerouslySkipPermissions": {
          "type": "boolean",
          "description": "允许跳过权限确认模式。仅建议在无网络访问的沙盒环境中使用。"
        },
        "claudeCode.claudeProcessWrapper": {
          "type": "string",
          "description": "用于启动 Claude 进程的可执行文件路径。"
        },
        "claudeCode.respectGitIgnore": {
          "type": "boolean",
          "default": true,
          "description": "搜索文件时遵守 .gitignore 规则。提示：禁用此选项后，仍可在 .ignore 中使用其他排除规则进行过滤。"
        },
        "claudeCode.initialPermissionMode": {
          "type": "string",
          "enum": [
            "default",
            "acceptEdits",
            "plan",
            "bypassPermissions"
          ],
          "default": "bypassPermissions",
          "description": "新对话的初始权限模式。"
        },
        "claudeCode.disableLoginPrompt": {
          "type": "boolean",
          "default": false,
          "description": "启用后，扩展将不再提示登录/认证。适用于外部处理认证的场景。"
        },
        "claudeCode.autosave": {
          "type": "boolean",
          "default": true,
          "description": "在 Claude 读取或写入文件前自动保存。"
        },
        "claudeCode.useCtrlEnterToSend": {
          "type": "boolean",
          "default": false,
          "description": "启用后，使用 Ctrl/Cmd+Enter 发送提示而非 Enter。这样 Enter 键可用于换行。"
        },
        "claudeCode.preSend": {
          "type": "boolean",
          "default": false,
          "description": "启用预发送模式：AI 运行时按 Tab 或 Enter 不会中断当前生成，而是将消息排队，等 AI 完成后自动发送。类似 Codex 的 Steer 预发送功能。"
        },
        "claudeCode.autoCompactEnabled": {
          "type": "boolean",
          "default": false,
          "description": "启用自动压缩：当上下文使用量超过 90% 时，当前任务完成后自动执行 /compact 压缩上下文。需要手动开启。"
        },
        "claudeCode.askUserQuestion": {
          "type": "boolean",
          "default": true,
          "description": "YOLO 模式下，当 Claude 主动提问（AskUserQuestion）时弹出选项让你手动选择，而不是自动跳过。关闭后 YOLO 会自动跳过所有提问。"
        },
        "claudeCode.preferredLocation": {
          "type": "string",
          "enum": [
            "sidebar",
            "panel"
          ],
          "enumDescriptions": [
            "侧边栏 (右侧)",
            "面板 (新标签页)"
          ],
          "default": "panel",
          "description": "Claude 默认打开的位置。当你在新位置打开 Claude 时，此设置会自动更新。"
        },
        "claudeCode.enableNewConversationShortcut": {
          "type": "boolean",
          "default": false,
          "description": "当 Claude 处于焦点时，使用 Cmd/Ctrl+N 快捷键开始新对话。"
        },
        "claudeCode.enableReopenClosedSessionShortcut": {
          "type": "boolean",
          "default": true,
          "description": "使用 Cmd/Ctrl+Shift+T 重新打开最近关闭的 Claude 会话标签页。仅当最后关闭的是 Claude 标签页时才拦截该快捷键，否则按 VS Code 默认行为重新打开关闭的编辑器。"
        },
        "claudeCode.hideOnboarding": {
          "type": "boolean",
          "default": false,
          "description": "隐藏 星迹的CC✨ 中的新手引导清单。"
        },
        "claudeCode.usePythonEnvironment": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "运行 Claude 时自动激活工作区的 Python 环境。需要安装 [Python](https://marketplace.visualstudio.com/items?itemName=ms-python.python) 扩展。"
        },
        "claudeCode.taskCompletionNotification": {
          "type": "boolean",
          "default": true,
          "description": "当任务完成且 Claude 面板不可见时，显示弹窗通知。"
        },
        "claudeCode.taskCompletionSound": {
          "type": "boolean",
          "default": true,
          "description": "当任务完成且 Claude 面板不可见时，播放提示音。"
        },
        "claudeCode.audioFeedback.enabled": {
          "type": "boolean",
          "default": false,
          "description": "启用自定义音频反馈，在任务完成、报错或 AI 提问时播放指定的音频文件（替代系统 beep 音）。"
        },
        "claudeCode.audioFeedback.completionSoundPath": {
          "type": "string",
          "default": "resources/audio/主人，任务已完成，请您查收~.mp3",
          "description": "任务完成时播放的音频文件路径（绝对路径或相对于扩展目录的路径，支持 mp3/wav/ogg/webm）。"
        },
        "claudeCode.audioFeedback.errorSoundPath": {
          "type": "string",
          "default": "resources/audio/糟糕，主人，好像遇到报错啦~快来救救我！.mp3",
          "description": "任务报错时播放的音频文件路径（绝对路径或相对于扩展目录的路径，支持 mp3/wav/ogg/webm）。"
        },
        "claudeCode.audioFeedback.questionSoundPath": {
          "type": "string",
          "default": "resources/audio/主人，我有个问题想问你。.mp3",
          "description": "AI 在 YOLO 模式下提问时播放的音频文件路径（绝对路径或相对于扩展目录的路径，支持 mp3/wav/ogg/webm）。"
        },
        "claudeCode.voice.ttsEnabled": {
          "type": "boolean",
          "default": false,
          "description": "启用语音朗读。Claude 回复后自动朗读文本。"
        },
        "claudeCode.voice.provider": {
          "type": "string",
          "enum": ["edge", "qwen", "mimo", "gemini"],
          "enumDescriptions": [
            "Edge TTS — 微软免费服务，无需 API 密钥，支持中文，零配置即用",
            "通义千问 Qwen TTS — 阿里云 DashScope，需 API 密钥，支持实时流式",
            "小米 MiMo TTS — 支持音色克隆、音色设计、情感语气标签",
            "Google Gemini TTS — 30 种预置音色，PCM 原始音频输出"
          ],
          "default": "edge",
          "description": "语音合成引擎。Edge 免费无需配置；其他引擎需先在下方填入 API 密钥。"
        },
        "claudeCode.voice.ttsRate": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 3.0,
          "default": 1.0,
          "description": "朗读语速倍率（0.5 = 慢速，1.0 = 正常，2.0 = 快速，3.0 = 极快）。对 Edge TTS 转换为 SSML prosody rate。"
        },
        "claudeCode.voice.chunkSize": {
          "type": "number",
          "minimum": 80,
          "maximum": 2000,
          "default": 250,
          "description": "每个合成块的最大字符数。长文本在句子边界切分，当前块播放时下一块并行合成以降低延迟。"
        },
        "claudeCode.voice.edge.voice": {
          "type": "string",
          "default": "zh-CN-XiaoxiaoNeural",
          "description": "Edge TTS 音色名称。常用中文：zh-CN-XiaoxiaoNeural（晓晓）、zh-CN-YunxiNeural（云希）、zh-CN-YunyangNeural（云扬）、zh-CN-XiaoyiNeural（晓伊）。完整列表参考 Edge TTS 文档。"
        },
        "claudeCode.voice.qwen.voice": {
          "type": "string",
          "enum": ["Cherry", "Serena", "Ethan", "Chelsie", "Kai", "Dylan", "Jada", "Sunny"],
          "default": "Cherry",
          "description": "Qwen TTS 音色。Cherry（推荐）、Serena、Ethan、Chelsie 支持全部模型；Kai / Dylan / Jada / Sunny 仅支持 Flash 模型。"
        },
        "claudeCode.voice.qwen.model": {
          "type": "string",
          "enum": ["qwen3-tts-flash", "qwen3-tts-instruct-flash"],
          "default": "qwen3-tts-flash",
          "description": "Qwen TTS 模型。qwen3-tts-flash 为快速合成；qwen3-tts-instruct-flash 支持语音指令（如「用温柔的语气朗读」）。"
        },
        "claudeCode.voice.qwen.endpoint": {
          "type": "string",
          "enum": ["china", "international"],
          "enumDescriptions": [
            "国内站 dashscope.aliyuncs.com（需国内 DashScope API Key）",
            "国际站 dashscope-intl.aliyuncs.com（需国际站 API Key）"
          ],
          "default": "china",
          "description": "Qwen DashScope 接入区域，需与 API Key 的站点一致。"
        },
        "claudeCode.voice.qwen.apiKey": {
          "type": "string",
          "default": "",
          "description": "阿里云 DashScope API Key。获取地址：https://dashscope.aliyun.com 。等同于环境变量 DASHSCOPE_API_KEY。保存在 VS Code SecretStorage 中。"
        },
        "claudeCode.voice.mimo.voice": {
          "type": "string",
          "enum": ["Chloe", "Mia", "Milo", "Dean", "冰糖", "茉莉", "苏打", "白桦"],
          "default": "Chloe",
          "description": "MiMo 预置音色。Chloe / Mia / Milo / Dean 为英文音色；冰糖 / 茉莉 / 苏打 / 白桦 为中文音色。"
        },
        "claudeCode.voice.mimo.model": {
          "type": "string",
          "enum": ["mimo-v2.5-tts", "mimo-v2.5-tts-voicedesign", "mimo-v2.5-tts-voiceclone", "mimo-v2-tts"],
          "enumDescriptions": [
            "预置音色（冰糖 / Chloe 等），支持唱歌模式与风格标签控制",
            "音色设计 — 用自然语言描述想要的音色，无需预置",
            "音色克隆 — 从 mp3/wav 样本（≤10 MB）克隆自定义音色",
            "旧版 V2 模型（仅支持 default_zh / default_en）"
          ],
          "default": "mimo-v2.5-tts",
          "description": "MiMo TTS 模型。v2.5 新增音色设计与音色克隆。"
        },
        "claudeCode.voice.mimo.baseUrl": {
          "type": "string",
          "default": "https://token-plan-cn.xiaomimimo.com/v1",
          "description": "MiMo Token Plan 接口地址。默认为国内 Token Plan 接入点。"
        },
        "claudeCode.voice.mimo.apiKey": {
          "type": "string",
          "default": "",
          "description": "MiMo Token Plan API Key（以 tp- 开头，非 sk- 按量计费密钥）。获取地址：https://token-plan-cn.xiaomimimo.com 。保存在 VS Code SecretStorage 中。"
        },
        "claudeCode.voice.gemini.voice": {
          "type": "string",
          "enum": ["Zephyr", "Puck", "Charon", "Kore", "Fenrir", "Leda", "Orus", "Aoede", "Autonoe", "Algieba", "Despina", "Algenib", "Schedar", "Achernar", "Sulafat"],
          "default": "Kore",
          "description": "Gemini 预置音色。推荐：Zephyr / Puck / Charon / Kore。共 30 个可选音色。"
        },
        "claudeCode.voice.gemini.model": {
          "type": "string",
          "enum": ["gemini-2.5-flash-preview-tts", "gemini-2.5-pro-preview-tts", "gemini-3.1-flash-tts-preview"],
          "default": "gemini-2.5-flash-preview-tts",
          "description": "Gemini TTS 模型。Flash 为快速推理；Pro 为高精度；3.1 为最新预览版。"
        },
        "claudeCode.voice.gemini.apiKey": {
          "type": "string",
          "default": "",
          "description": "Google AI Studio API Key（以 AIzaSy 开头）。获取地址：https://aistudio.google.com/apikey 。等同于环境变量 GEMINI_API_KEY 或 GOOGLE_API_KEY。保存在 VS Code SecretStorage 中。"
        },
        "claudeCode.codekey.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "启用 CodeKey 手机远程控制功能。开启后可通过手机远程审批 AI 操作、接收通知、发送消息。**需要先配对手机设备。**"
        },
        "claudeCode.codekey.relayServer": {
          "type": "string",
          "default": "ws://146.56.247.15/ws",
          "markdownDescription": "CodeKey 中继服务器 WebSocket 地址。默认使用官方服务器，可配置为自建服务器地址。"
        },
        "claudeCode.codekey.bridgePort": {
          "type": "number",
          "default": 3001,
          "markdownDescription": "Bridge HTTP 服务器端口（仅本地 127.0.0.1 可访问）。如遇端口冲突将自动递增。修改后需重启扩展。"
        },
        "claudeCode.codekey.approvalTimeout": {
          "type": "number",
          "default": 120,
          "minimum": 10,
          "maximum": 600,
          "markdownDescription": "权限审批超时时间（秒）。超时后将根据 `codekey.timeoutBehavior` 自动决定通过或拒绝。"
        },
        "claudeCode.codekey.timeoutBehavior": {
          "type": "string",
          "enum": ["deny", "allow"],
          "enumDescriptions": [
            "超时后自动拒绝（安全优先）",
            "超时后自动通过（效率优先）"
          ],
          "default": "deny",
          "markdownDescription": "审批超时后的默认行为。`deny` = 拒绝，`allow` = 通过。"
        },
        "claudeCode.codekey.privacyFilterEnabled": {
          "type": "boolean",
          "default": true,
          "description": "启用隐私过滤器。在事件推送到手机前，自动扫描并脱敏 API Key、Token、密码等敏感信息。"
        },
        "claudeCode.codekey.e2eEnabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "启用端到端加密。PC 与手机之间的所有消息使用 AES-256-GCM 加密传输，中继服务器无法解密。"
        },
        "claudeCode.codekey.requireApproval": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "AI 执行工具操作前需手机端审批。关闭后所有命令自动执行（类似 YOLO 模式），但仍会推送通知到手机。"
        },
        "claudeCode.codekey.askUserQuestionRemote": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "YOLO 模式下，将 Claude 的提问（AskUserQuestion）推送到手机端，可在手机上选择答案。"
        },
        "claudeCode.codekey.autoInstallHooks": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "自动在工作区的 `.claude/settings.local.json` 中安装 CodeKey Hook 脚本。关闭后需手动配置。"
        },
        "claudeCode.codekey.maxDevices": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 10,
          "description": "最大可绑定的移动设备数量。"
        },
        "claudeCode.codekey.neverPushTools": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["Read"],
          "description": "不推送到手机的 AI 工具列表。默认不推送 Read（读取文件）操作以减少干扰。"
        },
        "claudeCode.codekey.dndEnabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "免打扰模式。开启后审批请求不会推送到手机，改为本地 VS Code 弹窗审批。"
        }
      }
    },
    "jsonValidation": [
      {
        "fileMatch": [
          "**/.claude/settings.json",
          "**/.claude/settings.local.json",
          "**/ClaudeCode/managed-settings.json",
          "**/claude-code/managed-settings.json"
        ],
        "url": "./claude-code-settings.schema.json"
      }
    ],
    "commands": [
      {
        "command": "claude-vscode.editor.open",
        "title": "星迹的CC✨: 在新标签页中打开",
        "icon": {
          "light": "resources/claude-logo.svg",
          "dark": "resources/claude-logo.svg"
        }
      },
      {
        "command": "claude-vscode.editor.openLast",
        "title": "星迹的CC✨: 打开",
        "icon": {
          "light": "resources/claude-logo.svg",
          "dark": "resources/claude-logo.svg"
        }
      },
      {
        "command": "claude-vscode.primaryEditor.open",
        "title": "星迹的CC✨: 在主编辑器中打开",
        "icon": {
          "light": "resources/claude-logo.svg",
          "dark": "resources/claude-logo.svg"
        }
      },
      {
        "command": "claude-vscode.window.open",
        "title": "星迹的CC✨: 在新窗口中打开"
      },
      {
        "command": "claude-vscode.createWorktree",
        "title": "星迹的CC✨: 创建 Worktree"
      },
      {
        "command": "claude-vscode.sidebar.open",
        "title": "星迹的CC✨: 在侧边栏中打开",
        "icon": {
          "light": "resources/claude-logo.svg",
          "dark": "resources/claude-logo.svg"
        }
      },
      {
        "command": "claude-vscode.newConversation",
        "title": "星迹的CC✨: 新建对话"
      },
      {
        "command": "claude-vscode.reopenClosedSession",
        "title": "星迹的CC✨: 重新打开已关闭的会话"
      },
      {
        "command": "claude-vscode.update",
        "title": "星迹的CC✨: 更新扩展"
      },
      {
        "command": "claude-vscode.focus",
        "title": "星迹的CC✨: 聚焦输入框"
      },
      {
        "command": "claude-vscode.blur",
        "title": "星迹的CC✨: 取消聚焦"
      },
      {
        "command": "claude-vscode.logout",
        "title": "星迹的CC✨: 退出登录"
      },
      {
        "command": "claude-vscode.terminal.open",
        "title": "星迹的CC✨: 在终端中打开",
        "icon": {
          "light": "resources/claude-logo.svg",
          "dark": "resources/claude-logo.svg"
        }
      },
      {
        "command": "claude-vscode.acceptProposedDiff",
        "title": "星迹的CC✨: 接受建议的更改",
        "enablement": "claude-vscode.viewingProposedDiff",
        "icon": "$(check)"
      },
      {
        "command": "claude-vscode.rejectProposedDiff",
        "title": "星迹的CC✨: 拒绝建议的更改",
        "enablement": "claude-vscode.viewingProposedDiff",
        "icon": "$(discard)"
      },
      {
        "command": "claude-vscode.insertAtMention",
        "title": "星迹的CC✨: 插入 @提及 引用"
      },
      {
        "command": "claude-vscode.installPlugin",
        "title": "星迹的CC✨: 安装插件"
      },
      {
        "command": "claude-code.acceptProposedDiff",
        "title": "星迹的CC✨: 接受建议的更改",
        "enablement": "claude-code.viewingProposedDiff",
        "icon": "$(check)"
      },
      {
        "command": "claude-code.rejectProposedDiff",
        "title": "星迹的CC✨: 拒绝建议的更改",
        "enablement": "claude-code.viewingProposedDiff",
        "icon": "$(discard)"
      },
      {
        "command": "claude-code.insertAtMentioned",
        "title": "星迹的CC✨: 插入@提及"
      },
      {
        "command": "claude-vscode.showLogs",
        "title": "星迹的CC✨: 显示日志"
      },
      {
        "command": "claude-vscode.openWalkthrough",
        "title": "星迹的CC✨: 打开引导"
      },
      {
